<?xml version="1.0" encoding="UTF-8"?>
<!--
  AE Local Toolkit CEP 扩展清单文件
  定义扩展的标识、版本、支持的宿主程序（AE）、运行环境及界面配置
-->
<ExtensionManifest Version="7.0" ExtensionBundleId="com.local.aetoolkit" ExtensionBundleVersion="0.2.4" ExtensionBundleName="AE Local Toolkit" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.local.aetoolkit.panel" Version="0.2.4" />
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[17.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.local.aetoolkit.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/index.jsx</ScriptPath>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>AE Local Toolkit</Menu>
          <Geometry>
            <Size>
              <Height>620</Height>
              <Width>420</Width>
            </Size>
            <MinSize>
              <Height>520</Height>
              <Width>360</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
